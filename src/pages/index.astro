---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const techStack = ["Python", "TensorFlow", "RAG", "Oracle Cloud", "Docker", "NLP", "Gemini API", "React"];
---

<BaseLayout title="Henrique Barbosa | AI Engineer">
  
  <!-- HERO SECTION -->
  <header class="min-h-screen flex flex-col justify-center relative reveal">
    
    <!-- Status -->
    <div class="inline-flex items-center gap-2 px-3 py-1 w-fit rounded-full bg-white/5 border border-white/10 text-purple-300 text-xs font-mono mb-8 backdrop-blur-md hover:bg-white/10 transition-colors cursor-default">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse shadow-[0_0_10px_#4ade80]"></span>
      <span data-i18n="open">DISPONÍVEL PARA PROJETOS</span>
    </div>

    <!-- Nome e Título -->
    <h1 class="text-6xl md:text-8xl font-serif font-bold mb-6 text-white tracking-tighter drop-shadow-2xl">
      Henrique Barbosa<span class="text-purple-500">.</span>
    </h1>
    <h2 class="text-xl md:text-2xl font-mono text-purple-400 mb-8" data-i18n="role">
      Cientista de Dados & Eng. de IA
    </h2>

    <!-- Texto de Impacto -->
    <div class="text-lg md:text-xl font-sans text-slate-400 max-w-2xl leading-relaxed border-l-2 border-purple-500/50 pl-6 mb-12">
      <p data-i18n="heroText">
        Arquitetando a <span class="text-white font-bold bg-purple-600/20 px-1">inteligência autônoma</span> que redefine limites.
      </p>
      <p class="mt-4 text-sm text-slate-500" data-i18n="heroSub">
        Transformo o caos de dados corporativos em previsibilidade algorítmica e agentes que pensam.
      </p>
    </div>

    <!-- Botões de Contato -->
    <div class="flex flex-wrap gap-4">
      <a href="https://wa.me/5591981646532" target="_blank" class="px-8 py-4 bg-white text-black font-bold rounded hover:bg-purple-100 transition-colors flex items-center gap-2 group shadow-[0_0_20px_rgba(255,255,255,0.2)]">
        <span data-i18n="btnContact">Iniciar Transmissão</span>
        <span class="group-hover:translate-x-1 transition-transform">→</span>
      </a>
      <a href="mailto:byronkingdev@gmail.com" class="px-8 py-4 border border-white/10 text-white rounded hover:bg-white/5 transition-colors font-mono">
        Email Uplink
      </a>
    </div>
  </header>

  <!-- QUASAR DIVIDER -->
  <div class="quasar-line"></div>

  <!-- SKILLS & CHART -->
  <section id="skills" class="mb-32 reveal">
    <div class="grid md:grid-cols-2 gap-16 items-center">
      <div>
        <h2 class="text-sm font-bold font-mono text-purple-500 uppercase mb-8 tracking-widest" data-i18n="skillsTitle">
          Arsenal Tecnológico
        </h2>
        <div class="flex flex-wrap gap-3">
          {techStack.map(tech => (
            <span class="px-4 py-2 bg-[#1a103c]/30 border border-purple-500/20 rounded text-sm text-slate-300 hover:border-purple-500 hover:text-white transition-colors cursor-default backdrop-blur-sm">
              {tech}
            </span>
          ))}
        </div>
      </div>
      <div class="glass-panel p-6 rounded-2xl">
        <canvas id="skillsChart"></canvas>
      </div>
    </div>
  </section>

  <!-- EXPERIÊNCIA DETALHADA -->
  <section id="experiencia" class="mb-32 reveal">
    <h2 class="text-sm font-bold font-mono text-purple-500 uppercase mb-12 tracking-widest" data-i18n="expTitle">
      Missões Críticas
    </h2>
    
    <div class="space-y-16">
      <!-- SEDUC (DESTAQUE) -->
      <article class="relative pl-8 border-l-2 border-purple-500/30">
        <div class="absolute -left-[9px] top-0 w-4 h-4 bg-[#030014] border-2 border-purple-500 rounded-full shadow-[0_0_15px_#a855f7]"></div>
        
        <h3 class="text-3xl font-serif text-white mb-1">SEDUC - PA</h3>
        <div class="text-purple-400 font-mono text-sm mb-4" data-i18n="seducRole">Líder de Desenvolvimento & Inovação</div>
        
        <p class="text-slate-400 mb-6 max-w-3xl leading-relaxed" data-i18n="seducDesc">
          Responsável pela arquitetura e supervisão de todo o ecossistema de projetos.
        </p>

        <!-- Sub-projetos (Grid de Cards com Efeito 3D) -->
        <div class="grid md:grid-cols-2 gap-4 mt-6">
          <div class="supernova-card p-4 tilt-card" data-tilt>
            <h4 class="text-white font-bold mb-1">CortexIA 🧠</h4>
            <p class="text-xs text-slate-500" data-i18n="cortexDesc">Agente autônomo analista (Gemini API + RAG + NLP).</p>
          </div>
          <div class="supernova-card p-4 tilt-card" data-tilt>
            <h4 class="text-white font-bold mb-1">Sitec Web 🌐</h4>
            <p class="text-xs text-slate-500" data-i18n="sitecDesc">Gestão Full Stack integrando todas as ferramentas.</p>
          </div>
          <div class="supernova-card p-4 tilt-card" data-tilt>
            <h4 class="text-white font-bold mb-1">Ticker ⏱️</h4>
            <p class="text-xs text-slate-500" data-i18n="tickerDesc">Ponto eletrônico digital (Antes manual).</p>
          </div>
          <div class="supernova-card p-4 tilt-card" data-tilt>
            <h4 class="text-white font-bold mb-1">Reader & Hollides 📄</h4>
            <p class="text-xs text-slate-500" data-i18n="readerDesc">Automação de leitura de relatórios e férias.</p>
          </div>
        </div>
      </article>

      <!-- SEREDE -->
      <article class="relative pl-8 border-l-2 border-slate-700/30">
        <div class="absolute -left-[7px] top-0 w-3 h-3 bg-slate-700 rounded-full"></div>
        <h3 class="text-2xl font-serif text-slate-300 mb-1">Serede Rede Conecta</h3>
        <div class="text-slate-500 font-mono text-sm mb-4" data-i18n="seredeRole">Analista de Dados & Operações</div>
        <p class="text-slate-500 max-w-3xl" data-i18n="seredeDesc">
          Coleta e análise de dados operacionais. Monitoramento de KPIs de equipe e gestão de processos seletivos (Gupy/E-social). Otimização de fluxo documental.
        </p>
      </article>
    </div>
  </section>

  <!-- CERTIFICAÇÕES (Destaque Oracle com Tilt 3D) -->
  <section id="certificacoes" class="mb-32 reveal">
    <h2 class="text-sm font-bold font-mono text-purple-500 uppercase mb-8 tracking-widest" data-i18n="certTitle">
      Credenciais de Elite
    </h2>
    <div class="grid md:grid-cols-2 gap-6">
      <!-- Oracle 1 -->
      <div class="supernova-card p-6 border-l-4 border-l-red-500 tilt-card" data-tilt>
        <h3 class="text-white font-bold text-lg">Oracle Cloud Infrastructure 2025</h3>
        <p class="text-slate-400 text-sm">Certified Generative AI Professional</p>
      </div>
      <!-- Oracle 2 -->
      <div class="supernova-card p-6 border-l-4 border-l-red-500 tilt-card" data-tilt>
        <h3 class="text-white font-bold text-lg">Oracle Cloud Infrastructure</h3>
        <p class="text-slate-400 text-sm">Data Science Professional</p>
      </div>
      <!-- Google -->
      <div class="supernova-card p-6 border-l-4 border-l-blue-500 tilt-card" data-tilt>
        <h3 class="text-white font-bold text-lg">Google Analytics</h3>
        <p class="text-slate-400 text-sm">Certificação Profissional Google</p>
      </div>
      <!-- Recode -->
      <div class="supernova-card p-6 border-l-4 border-l-purple-500 tilt-card" data-tilt>
        <h3 class="text-white font-bold text-lg">Recode Pro AI</h3>
        <p class="text-slate-400 text-sm">Desenvolvimento Web & Backend</p>
      </div>
    </div>
  </section>

  <footer class="border-t border-white/5 py-12 text-center text-xs text-slate-600 font-mono" data-i18n="footer">
    © 2025 Henrique Barbosa. Arquitetado nas estrelas.
  </footer>

  <!-- Script Específico do Gráfico -->
  <script is:inline>
    window.addEventListener('load', function() {
      const ctx = document.getElementById('skillsChart')
      if(ctx && typeof Chart !== 'undefined') {
        new Chart(ctx, { // @ts-ignore
          type: 'radar',
          data: {
            labels: ['GenAI', 'Python', 'Cloud (Oracle/AWS)', 'Full Stack', 'Data Viz', 'Automação'],
            datasets: [{
              label: 'Proficiency',
              data: [95, 90, 85, 80, 88, 92],
              backgroundColor: 'rgba(168, 85, 247, 0.2)',
              borderColor: '#a855f7',
              pointBackgroundColor: '#fff',
              pointBorderColor: '#a855f7'
            }]
          },
          options: {
            scales: {
              r: {
                angleLines: { color: 'rgba(255, 255, 255, 0.05)' },
                grid: { color: 'rgba(255, 255, 255, 0.05)' },
                pointLabels: { color: '#94a3b8', font: { size: 11 } },
                ticks: { display: false, backdropColor: 'transparent' }
              }
            },
            plugins: { legend: { display: false } }
          }
        });
      }
    });
  </script>

</BaseLayout>