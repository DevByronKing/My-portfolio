---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// Dados manuais para a seção de Tech Stack (Adicione o que você usa)
const techStack = [
  "Python", "PyTorch", "TensorFlow", "SQL", "Docker", "AWS", "LangChain", "FastAPI"
];
---

<BaseLayout title="Seu Nome | Data Scientist">
  
  <!-- 1. HERO SECTION -->
  <header class="mb-32 mt-20 relative">
    <!-- Orb de Luz Roxa -->
    <div class="absolute -top-20 -left-20 w-64 h-64 bg-purple-600 rounded-full blur-[120px] opacity-20 pointer-events-none"></div>

    <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-white/5 border border-white/10 text-purple-300 text-xs font-mono tracking-widest mb-8">
      <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
      OPEN TO WORK
    </div>

    <h1 class="text-6xl sm:text-8xl font-serif font-bold mb-8 tracking-tighter text-white">
      [Seu Nome]<span class="text-purple-500">.</span>
    </h1>

    <div class="text-xl sm:text-2xl font-sans text-slate-400 max-w-2xl leading-relaxed border-l-2 border-purple-500/50 pl-6">
      <p>
        Cientista de Dados & Engenheiro de IA. <br>
        Especialista em criar <span class="text-white font-medium decoration-purple-500 decoration-1 underline underline-offset-4">inteligência acionável</span> a partir do caos.
      </p>
    </div>
  </header>

  <!-- 2. TECH STACK (NOVO) -->
  <section class="mb-32">
    <h2 class="text-sm font-bold font-mono tracking-widest text-slate-500 uppercase mb-8">
      Tech Stack & Ferramentas
    </h2>
    <div class="flex flex-wrap gap-4">
      {techStack.map((tech) => (
        <span class="px-4 py-2 rounded-md bg-white/5 border border-white/10 text-slate-300 font-mono text-sm hover:border-purple-500/50 hover:text-purple-300 transition-colors cursor-default">
          {tech}
        </span>
      ))}
    </div>
  </section>

  <!-- 3. PROJETOS (CORRIGIDO) -->
  <section class="mb-32">
    <div class="flex items-end justify-between mb-12 border-b border-white/10 pb-4">
      <h2 class="text-sm font-bold font-mono tracking-widest text-white uppercase">
        Projetos Selecionados
      </h2>
      <span class="text-xs text-slate-600 font-mono">2023 — 2024</span>
    </div>

    <div class="flex flex-col gap-16">
      {sortedProjects.map((project) => (
        <a href={`/projects/${project.slug}`} class="group block">
          <article class="flex flex-col sm:grid sm:grid-cols-12 gap-4 items-baseline">
            
            <!-- Ano -->
            <div class="sm:col-span-2 text-xs font-mono text-slate-500 group-hover:text-purple-400 transition-colors">
              {project.data.pubDate.getFullYear()}
            </div>

            <!-- Conteúdo -->
            <div class="sm:col-span-10">
              <h3 class="text-3xl font-serif text-white mb-3 group-hover:text-purple-400 transition-colors">
                {project.data.title}
              </h3>
              
              <p class="text-slate-400 leading-relaxed font-sans mb-4 max-w-prose">
                {project.data.description}
              </p>

              <div class="flex gap-3">
                {project.data.tags.map((tag) => (
                  <span class="text-xs font-bold font-mono text-slate-600 uppercase tracking-wider group-hover:text-slate-300 transition-colors">
                    #{tag}
                  </span>
                ))}
              </div>
            </div>

          </article>
        </a>
      ))}
    </div>
  </section>

  <!-- 4. SOBRE / FOOTER (NOVO) -->
  <footer class="border-t border-white/10 pt-16 pb-12">
    <div class="grid sm:grid-cols-2 gap-12">
      
      <!-- Coluna Sobre -->
      <div>
        <h3 class="text-white font-serif text-2xl mb-4">Sobre</h3>
        <p class="text-slate-400 leading-relaxed mb-6">
          Com background em Matemática e Computação, foco em resolver problemas reais de negócio usando Machine Learning. Atualmente explorando LLMs e RAG.
        </p>
        <a href="mailto:seuemail@exemplo.com" class="inline-flex items-center text-purple-400 hover:text-purple-300 font-mono text-sm group">
          Entrar em contato <span class="ml-2 group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>

      <!-- Coluna Links -->
      <div class="sm:text-right">
        <h3 class="text-white font-serif text-2xl mb-4">Links</h3>
        <div class="flex flex-col sm:items-end gap-2 font-mono text-sm text-slate-400">
          <a href="#" class="hover:text-white transition-colors">GitHub ↗</a>
          <a href="#" class="hover:text-white transition-colors">LinkedIn ↗</a>
          <a href="#" class="hover:text-white transition-colors">Twitter ↗</a>
        </div>
      </div>

    </div>
    
    <div class="mt-16 text-center text-xs text-slate-700 font-mono">
      © {new Date().getFullYear()} [Seu Nome]. Construído com Astro.
    </div>
  </footer>

</BaseLayout>