---
import '../styles/global.css';
import '@fontsource/lora';
import '@fontsource/inter';
const { title } = Astro.props;
---

<html lang="pt-br" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    
    <!-- FIX: Removido o 'defer' para garantir carregamento imediato -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  </head>
  <body class="bg-[#050505] overflow-x-hidden selection:bg-purple-500 selection:text-white">
    
    <!-- CURSOR PERSONALIZADO -->
    <div id="custom-cursor" class="hidden md:block"></div>
    <div id="custom-cursor-blur" class="hidden md:block"></div>

    <!-- FUNDO DE PARTÍCULAS (CANVAS) -->
    <canvas id="particles-canvas" class="fixed inset-0 z-[-1] pointer-events-none opacity-40"></canvas>

    <!-- CONTEÚDO -->
    <div class="max-w-5xl mx-auto px-6 py-12 relative z-10">
      <slot />
    </div>

    <!-- Script Principal -->
    <script src="../scripts/main.js"></script>
  </body>
</html>